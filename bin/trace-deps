#!/usr/bin/env ruby
# frozen_string_literal: true

# bin/trace-deps — Trace a test file's runtime dependencies.
#
# Usage:
#   bin/trace-deps --all                        # trace every test file (subprocess isolation)
#   bin/trace-deps --all --box                  # trace using Ruby::Box (experimental)
#   bin/trace-deps --shared                     # trace only test_helper.rb (tier 1)
#   bin/trace-deps test/example_test.rb         # trace a single file
#
# Isolation modes:
#   (default)  Each test is traced in a forked subprocess. Reliable,
#              works with all gems including native extensions.
#   --box      Uses Ruby::Box (RUBY_BOX=1) for in-process isolation.
#              Faster (no subprocess overhead) but experimental — may
#              crash with gems that have native C extensions due to the
#              Box CoW mechanism in Ruby 4.0.x. Native extensions are
#              pre-loaded in the main box as a workaround.
#
# Writes dependency graphs to .test-deps/<test_name>.json
# These are consumed by bin/compile-test-deps to generate nix/test-deps.nix

require 'bundler/setup'
require 'json'
require 'set'
require 'fileutils'
require 'open3'

PROJECT_ROOT = File.expand_path('..', __dir__)
DEPS_DIR = File.join(PROJECT_ROOT, '.test-deps')
TEST_ROOT = File.join(PROJECT_ROOT, 'test')

# Paths to exclude from the dependency graph — these are controlled
# by Gemfile.lock / Nix, not by project source changes.
EXCLUDE_PATTERNS = [
  '/vendor/',
  '/.bundle/',
  '/.gem/',
  '/gems/',
  '/rubygems/',
  '/bundler/',
].freeze

USE_BOX = ARGV.delete('--box')

def project_local?(path)
  return false unless path.start_with?(PROJECT_ROOT)
  EXCLUDE_PATTERNS.none? { |pat| path.include?(pat) }
end

def relative_path(path)
  path.delete_prefix("#{PROJECT_ROOT}/")
end

# ── Subprocess isolation (default) ────────────────────────────────────

module SubprocessTracer
  module_function

  def trace_test(test_file)
    abs_path = File.expand_path(test_file, PROJECT_ROOT)
    raise "File not found: #{abs_path}" unless File.exist?(abs_path)

    $stderr.puts "▶ Tracing #{test_file} (subprocess)..."

    script = <<~RUBY
      require 'bundler/setup'
      require 'rotoscope'
      require 'json'
      require 'set'

      PROJECT_ROOT = #{PROJECT_ROOT.inspect}
      EXCLUDE_PATTERNS = #{EXCLUDE_PATTERNS.inspect}

      def project_local?(path)
        return false unless path.start_with?(PROJECT_ROOT)
        EXCLUDE_PATTERNS.none? { |pat| path.include?(pat) }
      end

      deps = Set.new
      loaded_before = $LOADED_FEATURES.dup

      $LOAD_PATH.unshift(File.join(PROJECT_ROOT, 'lib'))
      $LOAD_PATH.unshift(File.join(PROJECT_ROOT, 'test'))

      rs = Rotoscope.new do |call|
        path = call.caller_path
        deps << path if path && project_local?(path)
      end

      rs.trace do
        load(#{abs_path.inspect})
      end

      ($LOADED_FEATURES - loaded_before).each do |path|
        deps << path if project_local?(path)
      end

      relative = deps.map { |p| p.delete_prefix(PROJECT_ROOT + "/") }.sort
      puts JSON.generate(relative)
    RUBY

    out, status = Open3.capture2(
      RbConfig.ruby, '-e', script,
      chdir: PROJECT_ROOT
    )

    unless status.success?
      raise "Trace failed for #{test_file} (exit #{status.exitstatus})"
    end

    json_line = out.lines.find { |l| l.strip.start_with?('[') }
    deps = JSON.parse(json_line)

    {
      test_file: relative_path(abs_path),
      deps: deps,
      traced_at: Time.now.utc.iso8601,
    }
  end

  def trace_shared
    $stderr.puts "▶ Tracing test_helper.rb (subprocess)..."
    helper_path = File.join(TEST_ROOT, 'test_helper.rb')

    script = <<~RUBY
      require 'bundler/setup'
      require 'rotoscope'
      require 'json'
      require 'set'

      PROJECT_ROOT = #{PROJECT_ROOT.inspect}
      EXCLUDE_PATTERNS = #{EXCLUDE_PATTERNS.inspect}

      def project_local?(path)
        return false unless path.start_with?(PROJECT_ROOT)
        EXCLUDE_PATTERNS.none? { |pat| path.include?(pat) }
      end

      deps = Set.new
      loaded_before = $LOADED_FEATURES.dup

      $LOAD_PATH.unshift(File.join(PROJECT_ROOT, 'lib'))
      $LOAD_PATH.unshift(File.join(PROJECT_ROOT, 'test'))

      rs = Rotoscope.new do |call|
        path = call.caller_path
        deps << path if path && project_local?(path)
      end

      rs.trace do
        load(#{helper_path.inspect})
      end

      ($LOADED_FEATURES - loaded_before).each do |path|
        deps << path if project_local?(path)
      end

      relative = deps.map { |p| p.delete_prefix(PROJECT_ROOT + "/") }.sort
      puts JSON.generate(relative)
    RUBY

    out, status = Open3.capture2(
      RbConfig.ruby, '-e', script,
      chdir: PROJECT_ROOT
    )

    raise "Trace failed for test_helper.rb" unless status.success?

    json_line = out.lines.find { |l| l.strip.start_with?('[') }
    deps = JSON.parse(json_line)

    {
      test_file: 'test/test_helper.rb',
      deps: deps,
      traced_at: Time.now.utc.iso8601,
    }
  end
end

# ── Ruby::Box isolation (experimental) ────────────────────────────────
#
# Uses Ruby::Box to give each test an isolated $LOADED_FEATURES without
# forking a subprocess. Requires RUBY_BOX=1 environment variable.
#
# Workaround: all native extensions are pre-loaded in the main box
# before creating any test boxes to reduce CoW overhead. The Box CoW
# mechanism in Ruby 4.0.x still copies native .bundle/.so files per box,
# which can cause crashes after several boxes are created.

module BoxTracer
  module_function

  def ensure_box_enabled!
    unless defined?(Ruby::Box) && Ruby::Box.enabled?
      $stderr.puts "error: Ruby::Box is not enabled. Run with RUBY_BOX=1 env var."
      $stderr.puts "  e.g.: RUBY_BOX=1 ruby bin/trace-deps --all --box"
      exit 1
    end
  end

  # Pre-load all native extensions in the main box so Box CoW
  # doesn't need to copy them (reduces crash likelihood).
  def preload_native_extensions!
    $stderr.puts "  Preloading native extensions in main box..."
    %w[
      json date psych prism cgi/escape nio4r
      io/console stringio erb zlib openssl socket
    ].each do |lib|
      begin
        require lib
      rescue LoadError
        # Some may not be available; that's fine
      end
    end
  end

  def make_box
    box = Ruby::Box.new
    $LOAD_PATH.each { |p| box.load_path << p }
    box.load_path.unshift(File.join(PROJECT_ROOT, 'lib'))
    box.load_path.unshift(File.join(PROJECT_ROOT, 'test'))
    box
  end

  def trace_in_box(file, use_load: false)
    box = make_box
    before = box.eval("$LOADED_FEATURES.dup")
    if use_load
      box.load(file)
    else
      box.require(file)
    end
    after = box.eval("$LOADED_FEATURES")
    (after - before)
      .select { |f| project_local?(f) }
      .map { |f| relative_path(f) }
      .sort
  end

  def trace_test(test_file)
    abs_path = File.expand_path(test_file, PROJECT_ROOT)
    raise "File not found: #{abs_path}" unless File.exist?(abs_path)

    $stderr.puts "▶ Tracing #{test_file} (box)..."
    deps = trace_in_box(test_file, use_load: true)

    {
      test_file: relative_path(abs_path),
      deps: deps,
      traced_at: Time.now.utc.iso8601,
    }
  end

  def trace_shared
    $stderr.puts "▶ Tracing test_helper.rb (box)..."
    deps = trace_in_box('test_helper')

    {
      test_file: 'test/test_helper.rb',
      deps: deps,
      traced_at: Time.now.utc.iso8601,
    }
  end
end

# ── Common helpers ────────────────────────────────────────────────────

def tracer
  if USE_BOX
    BoxTracer.ensure_box_enabled!
    BoxTracer.preload_native_extensions!
    BoxTracer
  else
    SubprocessTracer
  end
end

def write_deps(result)
  FileUtils.mkdir_p(DEPS_DIR)

  safe_name = result[:test_file].gsub('/', '--').sub(/\.rb$/, '')
  out_path = File.join(DEPS_DIR, "#{safe_name}.json")

  File.write(out_path, JSON.pretty_generate(result) + "\n")
  $stderr.puts "  → wrote #{out_path} (#{result[:deps].size} deps)"
end

def all_test_files
  Dir.glob(File.join(TEST_ROOT, '**/*_test.rb')).map { |f| relative_path(f) }
end

# ── Main ──────────────────────────────────────────────────────────────

case ARGV[0]
when '--all'
  t = tracer
  exit_code = 0
  write_deps(t.trace_shared)
  all_test_files.each do |f|
    begin
      write_deps(t.trace_test(f))
    rescue => e
      $stderr.puts "  ✗ #{f}: #{e.message}"
      exit_code = 1
    end
  end
  exit!(exit_code) # skip minitest's at_exit
when '--shared'
  write_deps(tracer.trace_shared)
when nil
  $stderr.puts "Usage: bin/trace-deps [--box] <test_file> | --all | --shared"
  exit 1
else
  t = tracer
  ARGV.each { |f| write_deps(t.trace_test(f)) }
end
