#!/usr/bin/env ruby

require 'rubygems'
require 'bundler/setup'

ROOT = File.expand_path('../..', __FILE__)
TEST_ROOT = ROOT + '/test'
DEPS_DIR = ROOT + '/.test-deps'

$LOAD_PATH.unshift(TEST_ROOT)

def test_files
  Dir.glob(TEST_ROOT + "/**/*_test.rb")
end

# ── Affected test resolution ──────────────────────────────────────────
# Given a list of changed files, find which tests are affected by
# consulting the traced dependency graphs in .test-deps/.

def load_dep_graph
  graph = {} # test_file => [dep, dep, ...]
  Dir.glob(DEPS_DIR + "/*.json").each do |f|
    data = JSON.parse(File.read(f))
    next if data["test_file"] == "test/test_helper.rb"
    graph[data["test_file"]] = data["deps"]
  end
  graph
end

def affected_tests(changed_files)
  require 'json'
  graph = load_dep_graph

  if graph.empty?
    $stderr.puts "No .test-deps/ found. Run `bin/trace-deps --all` first."
    $stderr.puts "Falling back to all tests."
    return test_files.map { |f| f.delete_prefix(ROOT + "/") }
  end

  changed = changed_files.map { |f| f.delete_prefix(ROOT + "/") }.to_set

  affected = Set.new

  # A changed file that is itself a test file should always run
  changed.each do |f|
    affected << f if graph.key?(f)
  end

  # Find tests whose deps include any changed file
  graph.each do |test_file, deps|
    affected << test_file if deps.any? { |d| changed.include?(d) }
  end

  affected.to_a.sort
end

def run_tests(files)
  if files.empty?
    puts "No affected tests."
    return true
  end

  files.each do |f|
    abs = f.start_with?('/') ? f : File.join(ROOT, f)
    require abs
  end
  true
end

# ── Watch mode ────────────────────────────────────────────────────────
# Polls lib/ and test/ for mtime changes and runs affected tests.

def watch
  require 'json'

  dirs = [ROOT + '/lib', ROOT + '/test']
  poll_interval = 1 # seconds

  # Snapshot mtimes
  snapshot = {}
  take_snapshot = -> {
    dirs.each do |dir|
      Dir.glob(dir + "/**/*.rb").each do |f|
        snapshot[f] = File.mtime(f)
      end
    end
  }

  take_snapshot.call
  puts "Watching lib/ and test/ for changes... (^C to stop)"

  loop do
    sleep poll_interval
    changed = []

    dirs.each do |dir|
      Dir.glob(dir + "/**/*.rb").each do |f|
        mtime = File.mtime(f)
        if snapshot[f] != mtime
          changed << f
          snapshot[f] = mtime
        end
      end
    end

    # Detect new files
    dirs.each do |dir|
      Dir.glob(dir + "/**/*.rb").each do |f|
        unless snapshot.key?(f)
          changed << f
          snapshot[f] = File.mtime(f)
        end
      end
    end

    next if changed.empty?

    rel = changed.map { |f| f.delete_prefix(ROOT + "/") }
    puts "\n#{Time.now.strftime('%H:%M:%S')} — changed: #{rel.join(', ')}"

    tests = affected_tests(changed)
    if tests.empty?
      puts "  No affected tests."
      next
    end

    puts "  Running: #{tests.join(', ')}"

    # Run in subprocess so minitest state doesn't accumulate
    pid = fork do
      ARGV.clear # prevent minitest from parsing parent's flags
      tests.each do |f|
        abs = f.start_with?('/') ? f : File.join(ROOT, f)
        load abs
      end
    end
    Process.wait(pid)
  end
rescue Interrupt
  puts "\nStopped."
end

# ── Main ──────────────────────────────────────────────────────────────

case ARGV[0]
when '--affected'
  require 'json'
  require 'set'
  files = ARGV.drop(1)
  ARGV.clear # prevent minitest from parsing our flags
  if files.empty?
    $stderr.puts "Usage: bin/testunit --affected file1.rb [file2.rb ...]"
    exit 1
  end
  tests = affected_tests(files)
  if tests.empty?
    puts "No affected tests."
    exit 0
  end
  puts "Running #{tests.size} affected test(s): #{tests.join(', ')}"
  run_tests(tests)
when '--watch'
  watch
when nil
  test_files.each { |f| require(f) }
  exit 0
else
  # A list of files is presumed to be specified
  ARGV.each do |a|
    require a.sub(%r{^test/}, '')
  end
end
