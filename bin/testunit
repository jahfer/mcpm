#!/usr/bin/env ruby

require 'rubygems'
require 'bundler/setup'

ROOT = File.expand_path('../..', __FILE__)
TEST_ROOT = ROOT + '/test'
DEPS_DIR = ROOT + '/.test-deps'

$LOAD_PATH.unshift(TEST_ROOT)

def test_files
  Dir.glob(TEST_ROOT + "/**/*_test.rb")
end

# ── Per-method affected resolution ────────────────────────────────────
# Given changed files, find which test METHODS are affected by
# consulting the per-method dependency graphs in .test-deps/.
#
# Returns an array of { test_file:, method: } hashes.

def load_method_graph
  tests = []   # [{ test_file:, method:, deps:, setup: }]
  setups = {}  # "Class#_setup" => [deps]

  Dir.glob(DEPS_DIR + "/*.json").each do |f|
    data = JSON.parse(File.read(f))
    if data["type"] == "setup"
      setups[data["method"]] = data["deps"]
    elsif data["type"] == "test"
      tests << data
    end
  end

  [tests, setups]
end

def affected_methods(changed_files)
  require 'json'
  require 'set'

  tests, setups = load_method_graph

  if tests.empty?
    $stderr.puts "No .test-deps/ found. Run `bin/trace-deps --all` first."
    $stderr.puts "Falling back to all tests."
    return test_files.map { |f| { "test_file" => f.delete_prefix(ROOT + "/"), "method" => nil } }
  end

  changed = changed_files.map { |f| f.delete_prefix(ROOT + "/") }.to_set

  affected = []

  tests.each do |t|
    method_deps = t["deps"].to_set

    # Include setup deps if this method has a setup dependency
    if t["setup"]
      setup_deps = (setups[t["setup"]] || []).to_set
      method_deps = method_deps | setup_deps
    end

    # Check if any dep was changed
    if method_deps.any? { |d| changed.include?(d) }
      affected << { "test_file" => t["test_file"], "method" => t["method"] }
    end

    # Also trigger if the test file itself was changed
    if changed.include?(t["test_file"])
      affected << { "test_file" => t["test_file"], "method" => t["method"] }
    end
  end

  affected.uniq
end

def run_affected(affected)
  if affected.empty?
    puts "No affected tests."
    return
  end

  # Group by test file so we can run methods together
  by_file = affected.group_by { |a| a["test_file"] }

  by_file.each do |test_file, methods|
    abs = File.join(ROOT, test_file)

    method_names = methods.filter_map { |m| m["method"] }
    if method_names.empty?
      # No method info — run whole file
      require abs
    else
      # Extract just the method name (after #)
      names = method_names.map { |m| m.split('#').last }
      # Build a regex to match any of the method names
      pattern = names.map { |n| Regexp.escape(n) }.join('|')
      ARGV.replace(["-n", "/#{pattern}/"])
      load abs
    end
  end
end

# ── Watch mode ────────────────────────────────────────────────────────

def watch
  require 'json'

  dirs = [ROOT + '/lib', ROOT + '/test']
  poll_interval = 1

  snapshot = {}
  dirs.each do |dir|
    Dir.glob(dir + "/**/*.rb").each { |f| snapshot[f] = File.mtime(f) }
  end

  puts "Watching lib/ and test/ for changes... (^C to stop)"

  loop do
    sleep poll_interval
    changed = []

    dirs.each do |dir|
      Dir.glob(dir + "/**/*.rb").each do |f|
        mtime = File.mtime(f)
        if snapshot[f] != mtime
          changed << f
          snapshot[f] = mtime
        elsif !snapshot.key?(f)
          changed << f
          snapshot[f] = mtime
        end
      end
    end

    next if changed.empty?

    rel = changed.map { |f| f.delete_prefix(ROOT + "/") }
    puts "\n#{Time.now.strftime('%H:%M:%S')} — changed: #{rel.join(', ')}"

    affected = affected_methods(changed)
    if affected.empty?
      puts "  No affected tests."
      next
    end

    labels = affected.map { |a| a["method"] || a["test_file"] }
    puts "  Running #{affected.size} method(s): #{labels.join(', ')}"

    pid = fork do
      ARGV.clear
      run_affected(affected)
    end
    Process.wait(pid)
  end
rescue Interrupt
  puts "\nStopped."
end

# ── Main ──────────────────────────────────────────────────────────────

case ARGV[0]
when '--affected'
  require 'json'
  require 'set'
  files = ARGV.drop(1)
  ARGV.clear
  if files.empty?
    $stderr.puts "Usage: bin/testunit --affected file1.rb [file2.rb ...]"
    exit 1
  end
  affected = affected_methods(files)
  if affected.empty?
    puts "No affected tests."
    exit 0
  end
  labels = affected.map { |a| a["method"] || a["test_file"] }
  puts "Running #{affected.size} affected method(s):"
  labels.each { |l| puts "  #{l}" }
  puts
  run_affected(affected)
when '--watch'
  watch
when nil
  test_files.each { |f| require(f) }
  exit 0
else
  ARGV.each do |a|
    require a.sub(%r{^test/}, '')
  end
end
