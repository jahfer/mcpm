#!/usr/bin/env ruby
# frozen_string_literal: true

# bin/compile-test-deps — Compile per-method .test-deps/*.json → nix/test-deps.nix
#
# Reads the per-method runtime dependency traces and generates a Nix
# attribute set that flake.nix uses to create per-method derivations.
#
# Setup deps are merged into each method's deps so Nix sees the full
# picture per derivation.

require 'json'

PROJECT_ROOT = File.expand_path('..', __dir__)
DEPS_DIR = File.join(PROJECT_ROOT, '.test-deps')
OUTPUT = File.join(PROJECT_ROOT, 'nix', 'test-deps.nix')

tests = []
setups = {}

Dir.glob(File.join(DEPS_DIR, '*.json')).sort.each do |f|
  data = JSON.parse(File.read(f))
  if data['type'] == 'setup'
    setups[data['method']] = data['deps']
  elsif data['type'] == 'test'
    tests << data
  end
end

if tests.empty?
  $stderr.puts "No test traces found in .test-deps/. Run `bin/trace-deps --all` first."
  exit 1
end

# Build Nix expression
lines = []
lines << '# Auto-generated by bin/compile-test-deps — do not edit by hand.'
lines << '# Per-method runtime dependencies traced by Rotoscope.'
lines << '# Each entry becomes a Nix derivation; deps are the precise set of'
lines << '# files whose code executed during that test method.'
lines << ''
lines << '['

tests.sort_by { |t| t['method'] }.each do |t|
  method_id = t['method']
  test_file = t['test_file']
  method_name = method_id.split('#').last

  # Merge setup deps into this method's deps
  setup_deps = t['setup'] ? (setups[t['setup']] || []) : []
  all_deps = (t['deps'] + setup_deps).uniq.sort
  boot = (t['boot_deps'] || []).sort

  # Nix-safe attribute name
  safe_name = method_id.gsub(/[:#]/, '-')

  lines << '  {'
  lines << "    name = #{safe_name.inspect};"
  lines << "    testFile = #{test_file.inspect};"
  lines << "    methodName = #{method_name.inspect};"
  lines << '    deps = ['
  all_deps.each do |dep|
    lines << "      #{dep.inspect}"
  end
  lines << '    ];'
  lines << '    bootDeps = ['
  boot.each do |dep|
    lines << "      #{dep.inspect}"
  end
  lines << '    ];'
  lines << '  }'
end

lines << ']'
lines << ''

File.write(OUTPUT, lines.join("\n"))
$stderr.puts "Wrote #{OUTPUT}"
$stderr.puts "  #{tests.size} method(s) from #{tests.map { |t| t['test_file'] }.uniq.size} file(s)"
