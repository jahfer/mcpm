#!/usr/bin/env ruby
# frozen_string_literal: true

# bin/compile-test-deps — Compile traced dependency graphs into nix/test-deps.nix
#
# Reads .test-deps/*.json files produced by bin/trace-deps and generates
# a Nix attribute set mapping test files to their source dependencies.
#
# Tier 1 (shared) deps from test_helper.rb are factored out — they're
# handled as shared infra in flake.nix. Per-test deps are the delta.
#
# Usage:
#   bin/compile-test-deps

require 'json'

PROJECT_ROOT = File.expand_path('..', __dir__)
DEPS_DIR = File.join(PROJECT_ROOT, '.test-deps')
OUTPUT = File.join(PROJECT_ROOT, 'nix', 'test-deps.nix')

# ── Load traced dependency graphs ─────────────────────────────────────

dep_files = Dir.glob(File.join(DEPS_DIR, '*.json')).sort
if dep_files.empty?
  $stderr.puts "No .test-deps/*.json files found. Run bin/trace-deps --all first."
  exit 1
end

traces = dep_files.map { |f| JSON.parse(File.read(f)) }

# ── Separate tier 1 (shared) from tier 2 (per-test) ──────────────────

shared_trace = traces.find { |t| t['test_file'] == 'test/test_helper.rb' }
shared_deps = shared_trace ? shared_trace['deps'].to_set : Set.new

test_traces = traces.reject { |t| t['test_file'] == 'test/test_helper.rb' }

# ── Generate nix/test-deps.nix ────────────────────────────────────────

nix_lines = []
nix_lines << '# Auto-generated by bin/compile-test-deps — do not edit by hand.'
nix_lines << '#'
nix_lines << '# Tier 1 (shared) deps from test_helper.rb are handled separately'
nix_lines << '# in flake.nix. The srcs listed here are the per-test delta.'
nix_lines << "#"
nix_lines << "# Shared deps (tier 1): #{shared_deps.to_a.sort.join(', ')}"
nix_lines << ''
nix_lines << '{'

# Also emit the shared deps so flake.nix can use them
nix_lines << '  _shared = {'
nix_lines << '    srcs = ['
shared_deps.to_a.sort.each do |dep|
  nix_lines << "      \"#{dep}\""
end
nix_lines << '    ];'
nix_lines << '  };'
nix_lines << ''

test_traces.sort_by { |t| t['test_file'] }.each do |trace|
  test_file = trace['test_file']
  # Per-test deps = traced deps minus shared deps minus the test file itself
  per_test_deps = (trace['deps'].to_set - shared_deps - Set[test_file]).to_a.sort

  nix_lines << "  \"#{test_file}\" = {"
  nix_lines << '    srcs = ['
  per_test_deps.each do |dep|
    nix_lines << "      \"#{dep}\""
  end
  nix_lines << '    ];'
  nix_lines << '  };'
  nix_lines << ''
end

nix_lines << '}'
nix_lines << ''

File.write(OUTPUT, nix_lines.join("\n"))
$stderr.puts "Wrote #{OUTPUT}"
$stderr.puts "  #{test_traces.size} test(s), #{shared_deps.size} shared dep(s)"
